{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "artport",
  "compatibility_date": "2026-04-22",
  "main": "./worker/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/sitemap.xml"]
  },
  "vars": {
    "SITE_URL": "https://artoir.net"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
